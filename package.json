{
  "name": "paperlyte-v2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "ci": "npm run lint && vitest run && npm run build",
    "generate:icons": "node scripts/generate-icons.js",
    "generate:mockups": "node scripts/generate-mockups.js",
    "generate-icons": "node scripts/generate-icons.js",
    "prebuild": "npm run generate:icons && npm run generate:mockups",
    "build": "tsc -b && vite build && node scripts/inject-dates.js",
    "postbuild": "node scripts/generate-sitemap.cjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{js,ts,json,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lighthouse": "npm run build && npx @lhci/cli autorun",
    "size": "size-limit"
  },
  "dependencies": {
    "@sentry/react": "^10.62.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "^2.0.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "sharp": "^0.34.5",
    "terser": "^5.48.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.5"
  },
  "size-limit": [
    {
      "name": "Main bundle (JS)",
      "path": "dist/assets/*.js",
      "limit": "150 KB",
      "gzip": true,
      "running": false
    },
    {
      "name": "Main bundle (CSS)",
      "path": "dist/assets/*.css",
      "limit": "30 KB",
      "gzip": true,
      "running": false
    }
  ],
  "overrides": {
    "axios": "^1.16.0",
    "basic-ftp": "^5.3.1",
    "ip-address": "^10.1.1",
    "brace-expansion": "^5.0.5",
    "flatted": "^3.4.2",
    "jiti": "^2.7.0",
    "js-yaml": "^4.2.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "path-to-regexp": "^0.1.13",
    "tmp": "^0.2.7",
    "undici": "^7.28.0",
    "extract-zip": {
      "yauzl": "^3.2.1"
    },
    "uuid": "^14.0.0"
  }
}
