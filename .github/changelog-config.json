{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["type: feature"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["type: bugfix"]
    },
    {
      "title": "## 📚 Documentation",
      "labels": ["documentation"]
    },
    {
      "title": "## 🔒 Security",
      "labels": ["security"]
    },
    {
      "title": "## 📦 Dependencies",
      "labels": ["dependencies", "automated"]
    },
    {
      "title": "## 🧹 CI/CD & Config",
      "labels": ["ci/cd", "config"]
    }
  ],
  "template": "${{CHANGELOG}}\n\n**Full Changelog**: ${{RELEASE_DIFF}}",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}})",
  "empty_template": "- No changes",
  "label_extractor": [
    {
      "pattern": "^(feat|feature)(\\(.*\\))?:",
      "target": "type: feature"
    },
    {
      "pattern": "^(fix|bugfix)(\\(.*\\))?:",
      "target": "type: bugfix"
    },
    {
      "pattern": "^docs(\\(.*\\))?:",
      "target": "documentation"
    },
    {
      "pattern": "^chore\\(deps.*\\):",
      "target": "dependencies"
    }
  ]
}
